  1575                           
  1576                           ;Config register CONFIG1 @ 0x8007
  1577                           ;	Oscillator Selection
  1578                           ;	FOSC = INTOSC, INTOSC oscillator: I/O function on CLKIN pin
  1579                           ;	Watchdog Timer Enable
  1580                           ;	WDTE = OFF, WDT disabled
  1581                           ;	Power-up Timer Enable
  1582                           ;	PWRTE = OFF, PWRT disabled
  1583                           ;	MCLR Pin Function Select
  1584                           ;	MCLRE = OFF, MCLR/VPP pin function is digital input
  1585                           ;	Flash Program Memory Code Protection
  1586                           ;	CP = OFF, Program memory code protection is disabled
  1587                           ;	Data Memory Code Protection
  1588                           ;	CPD = ON, Data memory code protection is enabled
